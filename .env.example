# AHlogu cloud provider selector
# Current options:
# noop     = local/offline only
# supabase = future Supabase provider
# aws      = future AWS provider
NEXT_PUBLIC_AHLOGU_CLOUD_PROVIDER=noop

# Existing ThingsBoard telemetry sync URL
# Keep this separate from AHlogu cloud/job management.
NEXT_PUBLIC_PROJECT_LOGU_SYNC_URL=https://ahconnect.automaticheating.com.au/api/v1/W3fZovDPT4Au9WuhnSar/telemetry
# Future AHlogu AWS API base URL
# Example: https://api.ahlogu.com
NEXT_PUBLIC_AHLOGU_API_URL=https://YOUR_API_ID.execute-api.ap-southeast-4.amazonaws.com
NEXT_PUBLIC_AWS_REGION=ap-southeast-4
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-southeast-4_c0BNFq52K
NEXT_PUBLIC_COGNITO_APP_CLIENT_ID=156dehti262j5cis659030k7m0
